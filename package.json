{
  "name": "openclaw-village-hub",
  "version": "1.0.0",
  "description": "OpenClaw hub for multiplayer worlds with OpenClaw-powered agents",
  "type": "module",
  "main": "index.js",
  "bin": {
    "village-hub": "./bin/village-hub.js"
  },
  "exports": {
    ".": "./index.js",
    "./world-loader": "./world-loader.js",
    "./helpers": "./helpers.js"
  },
  "files": [
    "hub.js",
    "server.js",
    "world-loader.js",
    "helpers.js",
    "index.js",
    "bin/",
    "lib/",
    "routes/",
    "worlds/campfire/"
  ],
  "scripts": {
    "start": "node server.js",
    "hub": "node hub.js",
    "test": "vitest run",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:watch": "vitest"
  },
  "vitest": {
    "testTimeout": 30000,
    "hookTimeout": 25000
  },
  "dependencies": {
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "vitest": "*"
  }
}
